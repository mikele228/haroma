# Copy to ".env" in the project root (or run: python scripts/setup_wizard.py)
# See mind/deploy_config.py and docs/getting-started.md

# Listen address (127.0.0.1 = local only; 0.0.0.0 = all interfaces)
# HAROMA_BIND_HOST=0.0.0.0

# HTTP port
# HAROMA_HTTP_PORT=8193

# Optional: require token on selected routes (mind/http_server_guards.py)
# HAROMA_HTTP_BEARER_TOKEN=

# Optional: POST rate limit per IP per route per minute (0 = off)
# HAROMA_HTTP_RATE_LIMIT_PER_MIN=0

# Optional: stderr JSON access logs
# HAROMA_STRUCTURED_LOG=0

# Optional: hint for on-robot bridge clients (documentation / your scripts)
# HAROMA_ROBOT_CLIENT_URL=http://127.0.0.1:8193

# --- Models by role (chat vs semantic memory vs emotion) ---
# Chat / generation: GGUF path in soul or models/; see engine/LLMBackend.py (HAROMA_GGUF_*, HAROMA_LLM_*).
# Semantic embeddings (NeuralEncoder): Hugging Face sentence encoder id (global default for all personas)
# HAROMA_SEMANTIC_ENCODER=sentence-transformers/all-MiniLM-L6-v2
# Per-persona semantic encoder (overrides global for that persona id): env suffix = persona id, uppercased, non-alnum -> _
# HAROMA_SEMANTIC_ENCODER_ANALYST=sentence-transformers/all-mpnet-base-v2
# Or set "semantic_encoder" on an entry in soul/agents.json initial_personas.
# Emotion classifier backbone (not chat; not NeuralEncoder): BERT-family encoder id
# HAROMA_EMOTION_ENCODER=google/mobilebert-uncased

# Vowpal Wabbit (optional): online LLM reward learner — requires pip install vowpalwabbit
# HAROMA_VW_REWARD=1

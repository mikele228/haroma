# Local deployment secrets (use .env.example as template)
.env

# Local runtime data and model weights (not tracked)
data/
models/

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Local virtualenv (scripts/setup_ubuntu.sh)
.venv/

# Soul identity — generated from scripts/soul_defaults via scripts/generate_soul.py
soul/*.json
